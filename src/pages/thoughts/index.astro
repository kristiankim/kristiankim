---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { thoughts as fallbackThoughts } from '../../data/content';
import { getPosts, isSanityConfigured } from '../../lib/sanity';

const sanityPosts = await getPosts();
const thoughts = sanityPosts.length
  ? sanityPosts.map((post) => ({
      slug: post.slug.current,
      title: post.title,
      category: post.category || 'Thoughts',
      publishedAt: (post.publishedAt || '').slice(0, 10),
      sections: [],
    }))
  : fallbackThoughts;
---

<BaseLayout title="Writings">
  <section class="section-block">
    <div class="section-header">
      <div class="section-heading">Writings</div>
    </div>

    {!isSanityConfigured && <p class="notice">Using local fallback content. Connect Sanity env vars to load CMS content.</p>}

    <div class="list">
      {thoughts.map((post) => (
        <article class="item">
          <div class="item-meta">{post.publishedAt}</div>
          <div class="item-meta">{post.category}</div>
          <a class="item-link" href={`/thoughts/${post.slug}`}>{post.title}</a>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .notice {
    margin-bottom: 16px;
  }

  .list {
    display: grid;
  }

  .item {
    display: grid;
    grid-template-columns: 260px 260px minmax(0, 1fr);
    gap: 24px;
    padding: 12px 0;
    border-bottom: 1px solid var(--line);
    align-items: center;
  }

  .item:last-child {
    border-bottom: 0;
  }

  .item-meta {
    color: var(--muted);
    font-size: 14px;
    line-height: 1.2857;
  }

  .item-link {
    text-decoration: none;
    font-size: 16px;
    line-height: 1.375;
  }

  .item-link:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  @media (max-width: 980px) {
    .item {
      grid-template-columns: 1fr;
      gap: 8px;
      align-items: start;
    }
  }
</style>
