---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { projects as fallbackProjects } from '../../data/content';
import { getProjects, isSanityConfigured } from '../../lib/sanity';

const sanityProjects = await getProjects();
const projects = sanityProjects.length
  ? sanityProjects.map((project) => ({
      ...project,
      slug: project.slug.current,
      teamMembers: project.teamMembers ?? [],
      impact: project.impact ?? [],
      isPrivate: Boolean(project.isPrivate),
      description: project.tldr || project.overview || '',
    }))
  : fallbackProjects.map((project) => ({
      ...project,
      description: project.overview || '',
    }));
---

<BaseLayout title="Works">
  <section class="section-block">
    <div class="section-header">
      <div class="section-heading">Works</div>
    </div>

    {!isSanityConfigured && <p class="notice">Using local fallback content. Connect Sanity env vars to load CMS content.</p>}

    <div class="list">
      {projects.map((project) => (
        <article class="item">
          <div class="item-meta">{project.company || 'Independent'}</div>
          <div class="item-meta">
            <span>{project.year || 'In progress'}</span>
            {project.isPrivate && <span>Private</span>}
          </div>
          <div class="item-copy">
            <h3><a href={`/works/${project.slug}`}>{project.title}</a></h3>
            <p>{project.description}</p>
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .notice {
    margin-bottom: 16px;
  }

  .list {
    display: grid;
  }

  .item {
    display: grid;
    grid-template-columns: 260px 260px minmax(0, 1fr);
    gap: 24px;
    padding: 12px 0;
    border-bottom: 1px solid var(--line);
    align-items: start;
  }

  .item:last-child {
    border-bottom: 0;
  }

  .item-meta {
    display: grid;
    gap: 2px;
    color: var(--muted);
    font-size: 14px;
    line-height: 1.2857;
  }

  .item-copy {
    display: grid;
    gap: 6px;
  }

  .item-copy h3 {
    font-size: 20px;
    line-height: 1.3;
    font-weight: 500;
  }

  .item-copy h3 a {
    text-decoration: none;
  }

  .item-copy h3 a:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  @media (max-width: 980px) {
    .item {
      grid-template-columns: 1fr;
      gap: 12px;
    }
  }
</style>
