---
import BaseLayout from '../layouts/BaseLayout.astro';

const colorTokens = [
  { name: 'bg', value: 'var(--bg)', note: 'App background' },
  { name: 'surface', value: 'var(--surface)', note: 'Card/surface background' },
  { name: 'text', value: 'var(--text)', note: 'Primary text' },
  { name: 'muted', value: 'var(--muted)', note: 'Secondary text' },
  { name: 'line', value: 'var(--line)', note: 'Borders/dividers' },
  { name: 'chip', value: 'var(--chip)', note: 'Chip/nav hover fill' },
];

const typeScale = [
  { token: 'display', sample: '3.35rem / -0.026em', usage: 'Hero headline' },
  { token: 'h1', sample: '2.6rem / -0.02em', usage: 'Page title' },
  { token: 'h2', sample: '2rem / -0.02em', usage: 'Section heading (article)' },
  { token: 'body', sample: '1rem / 1.75', usage: 'Primary paragraph' },
  { token: 'meta', sample: '0.82rem', usage: 'Meta/date/labels' },
];

const spacing = ['0.3rem', '0.45rem', '0.65rem', '0.9rem', '1.1rem', '1.5rem', '2.2rem'];
---

<BaseLayout title="Design Tokens">
  <section class="page">
    <h1>Design Tokens</h1>
    <p class="lead">Single-page visual reference for the current portfolio system (Atlassian-style token inventory).</p>

    <section class="block">
      <h2>Color</h2>
      <div class="colors">
        {colorTokens.map((token) => (
          <article>
            <div class="swatch" style={`background:${token.value}`}></div>
            <strong>{token.name}</strong>
            <code>{token.value}</code>
            <span>{token.note}</span>
          </article>
        ))}
      </div>
    </section>

    <section class="block">
      <h2>Typography</h2>
      <div class="table">
        {typeScale.map((row) => (
          <div class="row">
            <code>{row.token}</code>
            <span>{row.sample}</span>
            <span>{row.usage}</span>
          </div>
        ))}
      </div>
    </section>

    <section class="block">
      <h2>Spacing</h2>
      <div class="space-grid">
        {spacing.map((s) => (
          <article>
            <div class="space-bar" style={`width:${s}`}></div>
            <code>{s}</code>
          </article>
        ))}
      </div>
    </section>

    <section class="block">
      <h2>Radius + Border</h2>
      <div class="radius-grid">
        <article style="border-radius:.25rem">0.25rem</article>
        <article style="border-radius:.35rem">0.35rem</article>
        <article style="border-radius:.45rem">0.45rem</article>
        <article style="border-radius:999px">999px</article>
      </div>
    </section>

    <section class="block">
      <h2>Motion</h2>
      <div class="table">
        <div class="row"><code>--ease</code><span>220ms ease</span><span>Theme/background transitions</span></div>
        <div class="row"><code>hover</code><span>subtle color fill</span><span>Nav chips, links, cards</span></div>
      </div>
    </section>
  </section>
</BaseLayout>

<style>
  .page { max-width: 980px; }
  h1 { margin: 0 0 .6rem; font-size: clamp(1.8rem, 3.8vw, 2.8rem); letter-spacing: -.02em; }
  .lead { margin: 0; color: var(--muted); }
  .block { border-top: 1px solid var(--line); margin-top: 1.5rem; padding-top: 1rem; }
  h2 { margin: 0 0 .85rem; font-family: Inter, sans-serif; font-size: .95rem; }

  .colors { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: .8rem; }
  .colors article { border: 1px solid var(--line); border-radius: .45rem; padding: .65rem; background: var(--surface); display: grid; gap: .25rem; }
  .swatch { height: 52px; border-radius: .3rem; border: 1px solid var(--line); }
  code { font-size: .78rem; color: var(--muted); }
  .colors span { font-size: .82rem; color: var(--muted); }

  .table { border: 1px solid var(--line); border-radius: .45rem; overflow: hidden; }
  .row { display: grid; grid-template-columns: 120px 1fr 1fr; gap: .8rem; padding: .65rem .8rem; border-bottom: 1px solid var(--line); }
  .row:last-child { border-bottom: 0; }
  .row span { color: var(--muted); font-size: .9rem; }

  .space-grid { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: .7rem; }
  .space-grid article { border: 1px solid var(--line); border-radius: .45rem; padding: .7rem; background: var(--surface); }
  .space-bar { height: 10px; background: var(--text); border-radius: 999px; margin-bottom: .45rem; }

  .radius-grid { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: .7rem; }
  .radius-grid article { border: 1px solid var(--line); padding: 1rem .8rem; background: var(--surface); color: var(--muted); }

  @media (max-width: 820px) {
    .colors, .space-grid, .radius-grid { grid-template-columns: 1fr 1fr; }
    .row { grid-template-columns: 1fr; gap: .3rem; }
  }
</style>
