---
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  experiences,
  home,
  playground,
  projects as fallbackProjects,
  thoughts as fallbackThoughts,
} from '../data/content';
import { getPosts, getProjects, urlFor } from '../lib/sanity';

const sanityPosts = await getPosts();
const sanityProjects = await getProjects();

const writing = (sanityPosts.length
  ? sanityPosts.map((post) => ({
      slug: post.slug.current,
      title: post.title,
      category: post.category || 'Thoughts',
      publishedAt: (post.publishedAt || '').slice(0, 10),
    }))
  : fallbackThoughts.map((post) => ({
      slug: post.slug,
      title: post.title,
      category: post.category,
      publishedAt: post.publishedAt,
    }))
).sort((a, b) => (a.publishedAt < b.publishedAt ? 1 : -1));

const works = sanityProjects.length
  ? sanityProjects.map((project) => ({
      slug: project.slug.current,
      title: project.title,
      year: project.year || 'In progress',
      company: project.company || 'Independent',
      overview: project.overview || 'Details coming soon.',
      isPrivate: Boolean(project.isPrivate),
      coverImageUrl: project.cover?.asset ? urlFor(project.cover)?.width(1600).quality(85).url() : null,
      coverImageAlt: project.cover?.alt || project.title,
    }))
  : fallbackProjects.map((project) => ({
      slug: project.slug,
      title: project.title,
      year: project.year || 'In progress',
      company: project.company || 'Independent',
      overview: project.overview || 'Details coming soon.',
      isPrivate: Boolean(project.isPrivate),
      coverImageUrl: null,
      coverImageAlt: project.title,
    }));
---

<BaseLayout>
  <section class="home-hero twelve-col">
    <div class="hero-intro">
      <h1>{home.intro}</h1>
    </div>
    <div class="hero-body detail-copy">
      <p>{home.body}</p>
      <p>{home.longBio}</p>
    </div>
    <div class="hero-visual">
      <img
        src="/images/portrait.png"
        alt="Portrait"
        loading="lazy"
      />
    </div>
  </section>

  <section class="section-block">
    <div class="section-header">
      <div class="section-heading">Experiences</div>
    </div>
    <div class="works-list">
      {experiences.map((item) => (
        <article class="project-row">
          <div class="project-company">{item.company}</div>
          <div class="project-year">
            <span>{item.period}</span>
          </div>
          <div class="project-copy">
            <p class="project-summary">{item.summary}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section id="works" class="section-block">
    <div class="section-header">
      <div class="section-heading">Selected work</div>
    </div>
    <div class="selected-work-list">
      {works.map((project) => (
        <article class="selected-work-card">
          <div class="selected-work-copy">
            <div class="selected-work-meta">
              <span>{project.company}</span>
              <span>{project.year}</span>
              {project.isPrivate && <span>Private</span>}
            </div>
            <div class="selected-work-text">
              <a class="selected-work-link" href={`/works/${project.slug}`}>{project.title}</a>
              <p>{project.overview}</p>
            </div>
          </div>
          {project.coverImageUrl ? (
            <img class="selected-work-image" src={project.coverImageUrl} alt={project.coverImageAlt} loading="lazy" />
          ) : (
            <div class="selected-work-placeholder" aria-hidden="true"></div>
          )}
        </article>
      ))}
    </div>
  </section>

  <section id="thoughts" class="section-block">
    <div class="section-header">
      <div class="section-heading">Writings</div>
    </div>
    <div class="writing-list">
      {writing.map((post) => (
        <article class="writing-row">
          <div class="writing-date">{post.publishedAt}</div>
          <div class="writing-category">{post.category}</div>
          <a class="writing-link" href={`/thoughts/${post.slug}`}>{post.title}</a>
        </article>
      ))}
    </div>
  </section>

  <section id="playground" class="section-block">
    <div class="section-header">
      <div class="section-heading">Playground</div>
    </div>
    <div class="playground-grid">
      {playground.map((item) => (
        <article class="playground-card">
          <div class="playground-card-copy">
            <h2>{item.title}</h2>
            <p>{item.caption}</p>
            <a class="playground-card-link" href={item.thumb} target="_blank" rel="noreferrer">View</a>
          </div>
          <div class="playground-card-media">
            <div class="playground-browser">
              <div class="playground-browser-header" aria-hidden="true">
                <span></span>
                <span></span>
                <span></span>
              </div>
              <img src={item.thumb} alt={item.title} loading="lazy" />
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .home-hero {
    min-height: min(748px, calc(100vh - 190px));
    align-items: start;
  }

  .hero-intro,
  .hero-body,
  .hero-visual {
    align-self: start;
  }

  .hero-intro {
    grid-column: span 4;
    max-width: 402px;
  }

  .hero-intro h1 {
    font-size: clamp(2rem, 2.3vw, 2.6rem);
    line-height: 1.25;
  }

  .hero-body {
    grid-column: span 4;
    max-width: 402px;
  }

  .hero-visual {
    grid-column: span 4;
    justify-self: end;
    width: 100%;
  }

  .hero-visual img {
    width: min(402px, 100%);
    margin-left: auto;
    aspect-ratio: 402 / 528;
    object-fit: cover;
  }

  .works-list,
  .writing-list,
  .selected-work-list {
    display: grid;
  }

  .project-row,
  .writing-row {
    display: grid;
    grid-template-columns: 260px 260px minmax(0, 1fr);
    gap: 24px;
    padding: 12px 0;
    border-bottom: 1px solid var(--line);
    align-items: start;
  }

  .project-row:last-child,
  .writing-row:last-child {
    border-bottom: 0;
  }

  .project-company,
  .project-year,
  .writing-date,
  .writing-category {
    color: var(--muted);
    font-size: 14px;
    line-height: 1.2857;
  }

  .project-year {
    display: grid;
    gap: 2px;
  }

  .project-copy {
    display: grid;
    gap: 6px;
  }

  .project-summary {
    color: var(--text);
  }

  .project-copy a,
  .writing-link {
    color: var(--text);
    text-decoration: none;
    font-size: 16px;
    line-height: 1.375;
  }

  .project-copy a:hover,
  .writing-link:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .selected-work-list {
    gap: 24px;
  }

  .selected-work-card {
    display: grid;
    grid-template-columns: 544px minmax(0, 1fr);
    gap: 24px;
    padding-bottom: 24px;
    border-bottom: 1px solid var(--line-strong);
    align-items: start;
  }

  .selected-work-card:last-child {
    border-bottom: 0;
    padding-bottom: 0;
  }

  .selected-work-copy {
    display: grid;
    gap: 16px;
    max-width: 544px;
  }

  .selected-work-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 24px;
    color: var(--muted);
    font-size: 14px;
    line-height: 1.2857;
  }

  .selected-work-text {
    display: grid;
    gap: 4px;
  }

  .selected-work-link {
    color: var(--text);
    text-decoration: none;
    font-size: 24px;
    line-height: 1.1667;
    font-family: var(--font-serif);
  }

  .selected-work-link:hover {
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  .selected-work-image,
  .selected-work-placeholder {
    width: 100%;
    min-height: 420px;
    aspect-ratio: 1112 / 696;
    object-fit: cover;
  }

  .selected-work-placeholder {
    background:
      linear-gradient(135deg, rgba(23, 23, 23, 0.05), rgba(23, 23, 23, 0.12)),
      rgba(255, 255, 255, 0.6);
    border: 1px solid var(--line);
  }

  .playground-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 24px;
  }

  .playground-card {
    min-height: 495px;
    display: grid;
    grid-template-rows: auto 1fr;
    gap: 40px;
    padding-top: 24px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: #fff;
    overflow: clip;
  }

  .playground-card-copy {
    display: grid;
    gap: 8px;
    padding: 0 24px;
  }

  .playground-card-copy h2 {
    font-size: 24px;
    line-height: 1.1667;
  }

  .playground-card-copy p {
    height: 70px;
    overflow: hidden;
  }

  .playground-card-link {
    color: #1936ef;
    text-decoration: none;
    font-size: 16px;
    line-height: 1.375;
    width: fit-content;
  }

  .playground-card-link:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .playground-card-media {
    position: relative;
    min-height: 0;
    overflow: visible;
  }

  .playground-browser {
    position: absolute;
    inset: 0 auto auto calc(50% + 6px);
    width: min(91%, 495px);
    aspect-ratio: 495 / 314;
    transform: translate3d(-50%, 0, 0);
    border: 4px solid #ddd;
    border-radius: 16px;
    background: #fff;
    box-shadow: -17px 28px 0 5px rgba(97, 97, 97, 0.15);
    overflow: hidden;
    transition:
      transform 220ms ease,
      box-shadow 220ms ease;
    will-change: transform, box-shadow;
  }

  .playground-browser-header {
    display: flex;
    align-items: center;
    gap: 8px;
    height: 47px;
    padding: 0 18px;
    border-bottom: 1px solid #ececec;
    background: #f8f8f8;
  }

  .playground-browser-header span {
    width: 12px;
    height: 12px;
    border-radius: 999px;
    background: #d0d0d0;
  }

  .playground-browser img {
    width: 100%;
    height: calc(100% - 47px);
    object-fit: contain;
    object-position: top center;
    background: #f4f4f4;
  }

  .playground-card:hover .playground-browser {
    transform: translate3d(-50%, -8px, 0);
    box-shadow: -17px 36px 0 5px rgba(97, 97, 97, 0.18);
  }

  @media (max-width: 980px) {
    .home-hero {
      min-height: auto;
    }

    .hero-intro,
    .hero-body,
    .hero-visual {
      grid-column: auto;
      max-width: none;
    }

    .hero-visual img {
      width: 100%;
      max-width: 402px;
      margin-left: 0;
    }

    .project-row,
    .writing-row,
    .selected-work-card {
      grid-template-columns: 1fr;
      gap: 12px;
    }

    .selected-work-image,
    .selected-work-placeholder {
      min-height: 0;
    }

    .playground-grid {
      grid-template-columns: 1fr;
    }

    .playground-card {
      min-height: 0;
    }

    .playground-browser {
      position: relative;
      inset: auto;
      width: calc(100% - 32px);
      margin: 0 auto 16px;
      transform: none;
    }

    .playground-card:hover .playground-browser {
      transform: translateY(-6px);
    }
  }
</style>
