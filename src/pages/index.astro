---
import BaseLayout from '../layouts/BaseLayout.astro';
import { home, playground, projects as fallbackProjects, thoughts as fallbackThoughts } from '../data/content';
import { getPosts, getProjects } from '../lib/sanity';

const sanityPosts = await getPosts();
const sanityProjects = await getProjects();

const writing = (sanityPosts.length
  ? sanityPosts.map((post) => ({
      slug: post.slug.current,
      title: post.title,
      category: post.category || 'Thoughts',
      publishedAt: (post.publishedAt || '').slice(0, 10),
    }))
  : fallbackThoughts.map((post) => ({
      slug: post.slug,
      title: post.title,
      category: post.category,
      publishedAt: post.publishedAt,
    }))
).sort((a, b) => (a.publishedAt < b.publishedAt ? 1 : -1));

const works = sanityProjects.length
  ? sanityProjects.map((project) => ({
      slug: project.slug.current,
      title: project.title,
      year: project.year || 'In progress',
      company: project.company || 'Independent',
      overview: project.overview || 'Details coming soon.',
      isPrivate: Boolean(project.isPrivate),
    }))
  : fallbackProjects.map((project) => ({
      slug: project.slug,
      title: project.title,
      year: project.year || 'In progress',
      company: project.company || 'Independent',
      overview: project.overview || 'Details coming soon.',
      isPrivate: Boolean(project.isPrivate),
    }));
---

<BaseLayout>
  <section class="home-hero twelve-col">
    <div class="hero-intro">
      <h1>{home.intro}</h1>
    </div>
    <div class="hero-body detail-copy">
      <p>{home.body}</p>
      <p>{home.longBio}</p>
    </div>
    <div class="hero-visual">
      <img
        src="/images/portrait.png"
        alt="Portrait"
        loading="lazy"
      />
    </div>
  </section>

  <section class="section-block">
    <div class="section-header">
      <div class="section-heading">Works</div>
    </div>
    <div class="works-list">
      {works.map((project) => (
        <article class="project-row">
          <div class="project-company">{project.company}</div>
          <div class="project-year">
            <span>{project.year}</span>
            {project.isPrivate && <span>Private</span>}
          </div>
          <div class="project-copy">
            <a href={`/works/${project.slug}`}>{project.title}</a>
            <p>{project.overview}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="section-block">
    <div class="section-header">
      <div class="section-heading">Playground</div>
    </div>
    <div class="playground-list">
      {playground.map((item) => (
        <article class="playground-card">
          <div class="playground-copy">
            <h2>{item.title}</h2>
            <p>{item.caption}</p>
          </div>
          <img src={item.thumb} alt={item.title} loading="lazy" />
        </article>
      ))}
    </div>
  </section>

  <section class="section-block">
    <div class="section-header">
      <div class="section-heading">Writings</div>
    </div>
    <div class="writing-list">
      {writing.map((post) => (
        <article class="writing-row">
          <div class="writing-date">{post.publishedAt}</div>
          <div class="writing-category">{post.category}</div>
          <a class="writing-link" href={`/thoughts/${post.slug}`}>{post.title}</a>
        </article>
      ))}
    </div>
  </section>

  <section class="section-block">
    <div class="section-header">
      <div class="section-heading">More</div>
    </div>
    <div class="twelve-col">
      <div class="more-copy detail-copy">
        <p>{home.longBio}</p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .home-hero {
    min-height: min(816px, calc(100vh - 130px));
    align-items: start;
  }

  .hero-intro,
  .hero-body,
  .hero-visual {
    align-self: start;
  }

  .hero-intro {
    grid-column: span 4;
    max-width: 402px;
  }

  .hero-intro h1 {
    font-size: clamp(2rem, 2.3vw, 2.6rem);
    line-height: 1.25;
  }

  .hero-body {
    grid-column: span 4;
    max-width: 402px;
  }

  .hero-visual {
    grid-column: span 4;
    justify-self: end;
    width: 100%;
  }

  .hero-visual img {
    width: min(402px, 100%);
    margin-left: auto;
    aspect-ratio: 402 / 528;
    object-fit: cover;
  }

  .works-list,
  .writing-list,
  .playground-list {
    display: grid;
  }

  .project-row,
  .writing-row {
    display: grid;
    grid-template-columns: 260px 260px minmax(0, 1fr);
    gap: 24px;
    padding: 12px 0;
    border-bottom: 1px solid var(--line);
    align-items: start;
  }

  .project-row:last-child,
  .writing-row:last-child {
    border-bottom: 0;
  }

  .project-company,
  .project-year,
  .writing-date,
  .writing-category {
    color: var(--muted);
    font-size: 14px;
    line-height: 1.2857;
  }

  .project-year {
    display: grid;
    gap: 2px;
  }

  .project-copy {
    display: grid;
    gap: 6px;
  }

  .project-copy a,
  .writing-link {
    color: var(--text);
    text-decoration: none;
    font-size: 16px;
    line-height: 1.375;
  }

  .project-copy a:hover,
  .writing-link:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .playground-list {
    gap: 24px;
  }

  .playground-card {
    display: grid;
    grid-template-columns: 544px minmax(0, 1fr);
    gap: 24px;
    padding-bottom: 24px;
    border-bottom: 1px solid var(--line-strong);
    align-items: start;
  }

  .playground-card:last-child {
    border-bottom: 0;
    padding-bottom: 0;
  }

  .playground-copy {
    display: grid;
    gap: 8px;
    max-width: 544px;
  }

  .playground-copy h2 {
    font-size: 24px;
    line-height: 1.1667;
  }

  .playground-card img {
    width: 100%;
    min-height: 320px;
    aspect-ratio: 1112 / 696;
    object-fit: cover;
  }

  .more-copy {
    grid-column: 1 / span 4;
    max-width: 402px;
  }

  @media (max-width: 980px) {
    .home-hero {
      min-height: auto;
    }

    .hero-intro,
    .hero-body,
    .hero-visual,
    .more-copy {
      grid-column: auto;
      max-width: none;
    }

    .hero-visual img {
      width: 100%;
      max-width: 402px;
      margin-left: 0;
    }

    .project-row,
    .writing-row,
    .playground-card {
      grid-template-columns: 1fr;
      gap: 12px;
    }

    .playground-card img {
      min-height: 0;
    }
  }
</style>
