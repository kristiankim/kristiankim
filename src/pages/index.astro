---
import BaseLayout from '../layouts/BaseLayout.astro';
import { home, playground, thoughts as fallbackThoughts } from '../data/content';
import { getPosts } from '../lib/sanity';

const sanityPosts = await getPosts();
const writing = (sanityPosts.length
  ? sanityPosts.map((p) => ({
      slug: p.slug.current,
      title: p.title,
      publishedAt: (p.publishedAt || '').slice(0, 10),
    }))
  : fallbackThoughts.map((p) => ({
      slug: p.slug,
      title: p.title,
      publishedAt: p.publishedAt,
    }))
).sort((a, b) => (a.publishedAt < b.publishedAt ? 1 : -1));
---

<BaseLayout>
  <section class="hero tri-grid">
    <div class="section-label">Home</div>
    <div class="hero-copy">
      <h3>{home.intro}</h3>
      <p class="lead">{home.body}</p>
    </div>
    <img
      class="hero-portrait"
      src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?auto=format&fit=crop&w=1200&q=80"
      alt="Portrait"
      loading="lazy"
    />
  </section>

  <section class="section tri-grid">
    <div class="section-label">Projects</div>
    <p>Coming soon</p>
    <div></div>
  </section>

  <section class="section tri-grid">
    <div class="section-label">Playground</div>
    <div class="cards">
      {playground.map((item) => (
        <article>
          <div>
            <h3>{item.title}</h3>
            <p>{item.caption}</p>
          </div>
          <img src={item.thumb} alt={item.title} loading="lazy" />
        </article>
      ))}
    </div>
    <div></div>
  </section>

  <section class="section tri-grid">
    <div class="section-label">Writings</div>
    <ul class="writing-list">
      {writing.map((post, idx) => (
        <li class={idx === writing.length - 1 ? 'last' : ''}>
          <span>{post.publishedAt}</span>
          <a href={`/thoughts/${post.slug}`}>{post.title}</a>
        </li>
      ))}
    </ul>
    <div></div>
  </section>

  <section class="section tri-grid about-more">
    <div class="section-label">More</div>
    <p>{home.longBio}</p>
    <div></div>
  </section>
</BaseLayout>

<style>
  .tri-grid {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    gap: 1.4rem;
    align-items: start;
  }

  .tri-grid > .section-label { grid-column: span 4; }
  .tri-grid > .hero-copy,
  .tri-grid > .cards,
  .tri-grid > .writing-list,
  .tri-grid > p { grid-column: span 4; }
  .tri-grid > .hero-portrait,
  .tri-grid > div:last-child { grid-column: span 4; }

  .hero {
    min-height: 68vh;
    align-items: center;
  }

  .section {
    border-top: 1px solid var(--line);
    padding-top: 1.15rem;
    margin-top: 2.2rem;
  }

  .section-label {
    font-size: .84rem;
    color: var(--muted);
    letter-spacing: -.005em;
    padding-top: .2rem;
  }

  .hero-copy h3 {
    margin: 0 0 .8rem;
    font-size: clamp(1.15rem, 1.8vw, 1.6rem);
    line-height: 1.3;
    font-weight: 600;
    max-width: 40ch;
  }

  .lead {
    margin: 0;
    max-width: 66ch;
    color: var(--muted);
    font-size: .96rem;
    line-height: 1.72;
  }

  .hero-portrait {
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    border-radius: .15rem;
    transform: translate3d(0,0,0) scale(1.01);
    transition: transform 220ms linear;
    will-change: transform;
  }

  .cards {
    display: grid;
    gap: 1rem;
  }

  .cards article {
    border-top: 1px solid var(--line);
    padding-top: .9rem;
    display: grid;
    grid-template-columns: 1fr minmax(180px, 42%);
    gap: 1rem;
    align-items: start;
  }

  .cards h3 { margin: 0 0 .3rem; font-size: 1rem; }
  .cards p { margin: 0; color: var(--muted); font-size: .9rem; line-height: 1.64; }
  .cards img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border-radius: .15rem;
    transition: transform .35s ease, box-shadow .35s ease;
  }
  .cards img:hover { transform: scale(1.02); box-shadow: 0 10px 28px rgba(0,0,0,.08); }

  .writing-list { list-style: none; margin: 0; padding: 0; display: grid; }
  .writing-list li { display: grid; grid-template-columns: 120px 1fr; gap: 1rem; padding: .65rem 0; border-bottom: 1px solid var(--line); }
  .writing-list li.last { border-bottom: 0; }
  .writing-list span { color: var(--muted); font-size: .83rem; }
  .writing-list a { color: var(--text); text-decoration: none; font-size: .95rem; }

  .about-more p { margin: 0; color: var(--muted); line-height: 1.8; max-width: 72ch; }

  @media (max-width: 980px) {
    .tri-grid { grid-template-columns: 1fr; gap: .8rem; }
    .hero { min-height: auto; }
    .cards article { grid-template-columns: 1fr; }
    .writing-list li { grid-template-columns: 1fr; gap: .25rem; }
  }
</style>
