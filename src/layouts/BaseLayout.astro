---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Kristian Kim',
  description = 'Product designer crafting intuitive and user-centered experiences.',
} = Astro.props;

const fullTitle = title === 'Kristian Kim' ? title : `Kristian Kim — ${title}`;
---

<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <title>{fullTitle}</title>
  </head>
  <body>
    <div class="orb-bg" aria-hidden="true">
      <div class="orb-gradient"></div>
      <div class="orb-grid"></div>
      <div id="background-orb" class="orb"></div>
    </div>

    <header id="topnav" class="topnav">
      <div class="topnav-inner">
        <a class="brand" href="/">Kristian Kim</a>
        <nav>
          <a href="/works">Works</a>
          <a href="/thoughts">Thoughts</a>
          <a href="/about">About</a>
          <a href="/tokens">Tokens</a>
        </nav>
        <div aria-hidden="true"></div>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <script type="module">
      import Lenis from 'lenis';

      const nav = document.getElementById('topnav');
      const orb = document.getElementById('background-orb');

      const lenis = new Lenis({
        duration: 1.12,
        smoothWheel: true,
        wheelMultiplier: 0.9,
        touchMultiplier: 1.2,
      });

      const ORB_SIZE = 800;
      let isIdle = false;
      let idleTimer;
      let driftTimer;

      const centerX = window.innerWidth / 2 - ORB_SIZE / 2;
      const centerY = window.innerHeight / 2 - ORB_SIZE / 2;

      let currentX = centerX;
      let currentY = centerY;
      let targetX = centerX;
      let targetY = centerY;
      let vx = 0;
      let vy = 0;
      let stiffness = 0.08;
      let damping = 0.82;

      const animateOrb = () => {
        const dx = targetX - currentX;
        const dy = targetY - currentY;

        vx = (vx + dx * stiffness) * damping;
        vy = (vy + dy * stiffness) * damping;

        currentX += vx;
        currentY += vy;

        if (orb) {
          orb.style.transform = `translate3d(${currentX.toFixed(2)}px, ${currentY.toFixed(2)}px, 0)`;
        }
      };

      function raf(time) {
        lenis.raf(time);
        animateOrb();
        requestAnimationFrame(raf);
      }
      requestAnimationFrame(raf);

      const setActiveTracking = () => {
        isIdle = false;
        stiffness = 0.1;
        damping = 0.8;
      };

      const startIdleMode = () => {
        isIdle = true;
        stiffness = 0.02;
        damping = 0.93;

        clearInterval(driftTimer);
        driftTimer = setInterval(() => {
          const nextX = targetX + (Math.random() * 400 - 200);
          const nextY = targetY + (Math.random() * 400 - 200);
          const boundedX = Math.max(-ORB_SIZE / 2, Math.min(window.innerWidth - ORB_SIZE / 2, nextX));
          const boundedY = Math.max(-ORB_SIZE / 2, Math.min(window.innerHeight - ORB_SIZE / 2, nextY));
          targetX = boundedX;
          targetY = boundedY;
        }, 4000);
      };

      const resetIdleTimer = () => {
        clearTimeout(idleTimer);
        clearInterval(driftTimer);
        idleTimer = setTimeout(startIdleMode, 1000);
      };

      window.addEventListener('mousemove', (e) => {
        setActiveTracking();
        targetX = e.clientX - ORB_SIZE / 2;
        targetY = e.clientY - ORB_SIZE / 2;
        resetIdleTimer();
      }, { passive: true });

      resetIdleTimer();

      window.addEventListener('scroll', () => {
        if (!nav) return;
        const y = window.scrollY;
        nav.classList.toggle('scrolled', y > 16);

        const blur = Math.min(16, 4 + y * 0.02);
        nav.style.setProperty('--nav-blur', `${blur.toFixed(2)}px`);

        if (heroMedia) {
          const drift = Math.min(18, y * 0.05);
          heroMedia.style.transform = `translate3d(0, ${drift.toFixed(2)}px, 0) scale(1.01)`;
        }
      }, { passive: true });

      const revealSelectors = [
        '.hero-copy',
        '.hero-portrait',
        '.section-label',
        '.cards article',
        '.writing-list li',
        '.list li',
        '.content-image',
        '.gallery-grid img',
        '.quote-block',
        '.callout-block',
        '.metrics-grid article',
        '.about-more p'
      ];

      const heroMedia = document.querySelector('.hero img');

      const revealNodes = document.querySelectorAll(revealSelectors.join(','));

      revealNodes.forEach((node, idx) => {
        node.classList.add('reveal-item');

        const isHeroText = node.matches('.hero-copy');
        const isHeroImage = node.matches('.hero-portrait');
        const isCard = node.matches('.cards article, .writing-list li, .list li, .metrics-grid article');
        const isTextBlock = node.matches('.section-label, .quote-block, .callout-block, .about-more p');

        const baseDelay = isHeroText ? 0 : isHeroImage ? 200 : isCard ? 90 : isTextBlock ? 40 : 20;
        const stagger = isCard ? (idx % 6) * 55 : (idx % 4) * 35;
        const duration = isHeroImage ? 820 : isHeroText ? 760 : isTextBlock ? 740 : 660;
        const distance = isHeroImage ? 26 : isHeroText ? 18 : isTextBlock ? 18 : 14;

        node.style.setProperty('--reveal-delay', `${baseDelay + stagger}ms`);
        node.style.setProperty('--reveal-duration', `${duration}ms`);
        node.style.setProperty('--reveal-distance', `${distance}px`);
      });

      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.13, rootMargin: '0px 0px -10% 0px' });

      revealNodes.forEach((node) => observer.observe(node));
    </script>
  </body>
</html>

<style>
  :root {
    --max: min(1680px, calc(100vw - 2.4rem));
    --ease: 220ms ease;
    --font-sans: "Inter", "SF Pro Text", "Helvetica Neue", Helvetica, Arial, sans-serif;
    --font-serif: "Inter", "SF Pro Text", "Helvetica Neue", Helvetica, Arial, sans-serif;
  }

  html[data-theme='light'] {
    color-scheme: light;
    --bg: #f7f7f7;
    --surface: #ffffff;
    --text: #171717;
    --muted: #626262;
    --line: #e8e8e8;
    --chip: #f0f0f0;
    --nav-bg: color-mix(in oklab, white 80%, transparent);
  }

  html[data-theme='dark'] {
    color-scheme: dark;
    --bg: #0f0f0f;
    --surface: #171717;
    --text: #f3f3f3;
    --muted: #9c9c9c;
    --line: #2a2a2a;
    --chip: #222;
    --nav-bg: color-mix(in oklab, #171717 76%, transparent);
  }

  * { box-sizing: border-box; }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    background: var(--bg);
    color: var(--text);
    font-family: var(--font-sans);
    font-weight: 400;
    line-height: 1.62;
    letter-spacing: -0.005em;
    text-rendering: optimizeLegibility;
    -webkit-font-smoothing: antialiased;
    transition: background var(--ease), color var(--ease);
    position: relative;
    overflow-x: hidden;
  }

  h1, h2, h3 {
    font-family: var(--font-sans);
    font-weight: 600;
    line-height: 1.08;
    letter-spacing: -0.018em;
  }

  .orb-bg {
    position: fixed;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
    z-index: 0;
    background: #faf9f6;
  }

  .orb-gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, #fdfbf7 0%, #faf9f6 52%, #faf9f6 100%);
  }

  .orb-grid {
    position: absolute;
    inset: 0 auto 0 0;
    width: 33%;
    opacity: .06;
    background-image:
      linear-gradient(to right, #d2b48c 1px, transparent 1px),
      linear-gradient(to bottom, #d2b48c 1px, transparent 1px);
    background-size: 40px 40px;
    mask-image: linear-gradient(to right, black, transparent);
  }

  .orb {
    position: absolute;
    width: 800px;
    height: 800px;
    border-radius: 999px;
    opacity: .58;
    mix-blend-mode: multiply;
    filter: blur(80px);
    background: radial-gradient(circle at center, rgba(210,180,140,.56) 0%, rgba(222,184,135,.36) 50%, transparent 70%);
    transform: translate3d(-400px, -400px, 0);
    will-change: transform;
  }

  .topnav {
    position: sticky;
    top: 0;
    z-index: 50;
    border-bottom: 1px solid var(--line);
    background: color-mix(in oklab, var(--bg) 88%, transparent);
    backdrop-filter: blur(var(--nav-blur, 6px));
    -webkit-backdrop-filter: blur(var(--nav-blur, 6px));
  }

  .topnav,
  main {
    position: relative;
    z-index: 10;
  }

  .topnav-inner {
    max-width: var(--max);
    margin: 0 auto;
    padding: .8rem 1.25rem;
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    align-items: center;
  }

  .brand {
    color: var(--text);
    text-decoration: none;
    font-family: var(--font-sans);
    font-weight: 600;
    letter-spacing: -0.012em;
    font-size: .95rem;
    white-space: nowrap;
  }

  nav {
    display: flex;
    gap: .9rem;
    align-items: center;
    justify-self: start;
  }

  nav a {
    color: var(--muted);
    text-decoration: none;
    font-size: 0.86rem;
    padding: 0;
    transition: color var(--ease);
  }

  nav a:hover {
    color: var(--text);
  }

  main {
    max-width: var(--max);
    margin: 0 auto;
    padding: 2.1rem 1.25rem 5rem;
  }

  .reveal-item {
    --reveal-delay: 0ms;
    --reveal-duration: 680ms;
    --reveal-distance: 16px;
    opacity: 0;
    transform: translateY(var(--reveal-distance));
    transition:
      opacity var(--reveal-duration) cubic-bezier(.22,.61,.36,1) var(--reveal-delay),
      transform calc(var(--reveal-duration) + 80ms) cubic-bezier(.22,.61,.36,1) var(--reveal-delay);
    will-change: opacity, transform;
  }

  .reveal-item.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .reveal-item {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }

  @media (max-width: 860px) {
    .topnav-inner {
      grid-template-columns: 1fr;
      gap: .35rem;
      padding: .75rem 1rem;
    }
    nav {
      overflow-x: auto;
      padding-bottom: 2px;
      gap: .75rem;
    }
  }
</style>
