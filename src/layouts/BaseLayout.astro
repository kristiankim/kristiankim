---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Kristian Kim',
  description = 'Product designer crafting intuitive and user-centered experiences.',
} = Astro.props;

const fullTitle = title === 'Kristian Kim' ? title : `Kristian Kim — ${title}`;
---

<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <title>{fullTitle}</title>
  </head>
  <body>
    <header id="topnav" class="topnav">
      <div class="topnav-inner">
        <a class="brand" href="/">Kristian Kim</a>
        <div class="header-actions">
          <nav>
            <a href="/works">Works</a>
            <a href="/thoughts">Thoughts</a>
            <a href="/about">About</a>
            <a href="/tokens">Tokens</a>
          </nav>
          <button id="theme-toggle" aria-label="Toggle dark mode" type="button">Dark</button>
        </div>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <script type="module">
      import Lenis from 'lenis';

      const key = 'kristiankim-theme';
      const root = document.documentElement;
      const button = document.getElementById('theme-toggle');
      const nav = document.getElementById('topnav');

      const applyTheme = (theme) => {
        root.setAttribute('data-theme', theme);
        if (button) button.textContent = theme === 'dark' ? 'Light' : 'Dark';
      };

      const stored = localStorage.getItem(key);
      applyTheme(stored === 'dark' ? 'dark' : 'light');

      button?.addEventListener('click', () => {
        const current = root.getAttribute('data-theme') === 'dark' ? 'dark' : 'light';
        const next = current === 'dark' ? 'light' : 'dark';
        localStorage.setItem(key, next);
        applyTheme(next);
      });

      const lenis = new Lenis({
        duration: 1.12,
        smoothWheel: true,
        wheelMultiplier: 0.9,
        touchMultiplier: 1.2,
      });

      function raf(time) {
        lenis.raf(time);
        requestAnimationFrame(raf);
      }
      requestAnimationFrame(raf);

      let lastY = window.scrollY;
      window.addEventListener('scroll', () => {
        if (!nav) return;
        const y = window.scrollY;
        nav.classList.toggle('scrolled', y > 16);

        if (y > lastY && y > 120) {
          nav.classList.add('scroll-down');
          nav.classList.remove('scroll-up');
        } else {
          nav.classList.remove('scroll-down');
          nav.classList.add('scroll-up');
        }
        lastY = y;
      }, { passive: true });

      const revealSelectors = [
        'main section',
        '.cards article',
        '.writing-list li',
        '.list li',
        '.hero img',
        '.content-image',
        '.gallery-grid img',
        '.quote-block',
        '.callout-block',
        '.metrics-grid article'
      ];

      const revealNodes = document.querySelectorAll(revealSelectors.join(','));

      revealNodes.forEach((node, idx) => {
        node.classList.add('reveal-item');

        const isHero = node.matches('.hero img');
        const isCard = node.matches('.cards article, .writing-list li, .list li, .metrics-grid article');
        const isTextBlock = node.matches('main section, .quote-block, .callout-block');

        const baseDelay = isHero ? 120 : isCard ? 90 : isTextBlock ? 40 : 20;
        const stagger = isCard ? (idx % 6) * 55 : (idx % 4) * 35;
        const duration = isHero ? 900 : isTextBlock ? 760 : 680;
        const distance = isHero ? 28 : isTextBlock ? 20 : 14;

        node.style.setProperty('--reveal-delay', `${baseDelay + stagger}ms`);
        node.style.setProperty('--reveal-duration', `${duration}ms`);
        node.style.setProperty('--reveal-distance', `${distance}px`);
      });

      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.13, rootMargin: '0px 0px -10% 0px' });

      revealNodes.forEach((node) => observer.observe(node));
    </script>
  </body>
</html>

<style>
  :root {
    --max: 1080px;
    --ease: 220ms ease;
    --font-sans: "Inter", "SF Pro Text", "Helvetica Neue", Helvetica, Arial, sans-serif;
    --font-serif: "Inter", "SF Pro Text", "Helvetica Neue", Helvetica, Arial, sans-serif;
  }

  html[data-theme='light'] {
    color-scheme: light;
    --bg: #f7f7f7;
    --surface: #ffffff;
    --text: #171717;
    --muted: #626262;
    --line: #e8e8e8;
    --chip: #f0f0f0;
    --nav-bg: color-mix(in oklab, white 80%, transparent);
  }

  html[data-theme='dark'] {
    color-scheme: dark;
    --bg: #0f0f0f;
    --surface: #171717;
    --text: #f3f3f3;
    --muted: #9c9c9c;
    --line: #2a2a2a;
    --chip: #222;
    --nav-bg: color-mix(in oklab, #171717 76%, transparent);
  }

  * { box-sizing: border-box; }

  body {
    margin: 0;
    background: var(--bg);
    color: var(--text);
    font-family: var(--font-sans);
    font-weight: 400;
    line-height: 1.62;
    letter-spacing: -0.005em;
    text-rendering: optimizeLegibility;
    -webkit-font-smoothing: antialiased;
    transition: background var(--ease), color var(--ease);
  }

  h1, h2, h3 {
    font-family: var(--font-sans);
    font-weight: 600;
    line-height: 1.08;
    letter-spacing: -0.018em;
  }

  .topnav {
    position: sticky;
    top: 1rem;
    z-index: 50;
    transition: transform .35s cubic-bezier(.617,1.5,.68,1), opacity .35s ease;
  }

  .topnav.scroll-down {
    transform: translateY(-135%);
    opacity: 0;
  }

  .topnav.scroll-up,
  .topnav:not(.scroll-down) {
    transform: translateY(0);
    opacity: 1;
  }

  .topnav-inner {
    max-width: min(var(--max), 960px);
    margin: 0 auto;
    padding: .66rem .9rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: var(--nav-bg);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
  }

  .brand {
    color: var(--text);
    text-decoration: none;
    font-family: var(--font-sans);
    font-weight: 600;
    letter-spacing: -0.012em;
    font-size: .95rem;
    white-space: nowrap;
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  nav {
    display: flex;
    gap: 0.2rem;
    align-items: center;
  }

  nav a {
    color: var(--muted);
    text-decoration: none;
    font-size: 0.9rem;
    padding: 0.34rem 0.58rem;
    border-radius: 999px;
    transition: color var(--ease), background var(--ease);
  }

  nav a:hover {
    color: var(--text);
    background: var(--chip);
  }

  #theme-toggle {
    border: 1px solid var(--line);
    background: transparent;
    color: var(--text);
    border-radius: 999px;
    padding: 0.34rem 0.58rem;
    cursor: pointer;
    font-size: 0.78rem;
    line-height: 1;
  }

  main {
    max-width: var(--max);
    margin: 0 auto;
    padding: 2.1rem 1.25rem 5rem;
  }

  .reveal-item {
    --reveal-delay: 0ms;
    --reveal-duration: 680ms;
    --reveal-distance: 16px;
    opacity: 0;
    transform: translateY(var(--reveal-distance));
    transition:
      opacity var(--reveal-duration) cubic-bezier(.22,.61,.36,1) var(--reveal-delay),
      transform calc(var(--reveal-duration) + 80ms) cubic-bezier(.22,.61,.36,1) var(--reveal-delay);
    will-change: opacity, transform;
  }

  .reveal-item.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .reveal-item {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }

  @media (max-width: 860px) {
    .topnav { top: .65rem; }
    .topnav-inner {
      border-radius: 1rem;
      max-width: calc(100% - 1rem);
      align-items: flex-start;
      gap: .6rem;
      flex-direction: column;
    }
    .header-actions { width: 100%; justify-content: space-between; }
    nav { overflow-x: auto; padding-bottom: 2px; }
  }
</style>
