---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Kristian Kim',
  description = 'Product designer crafting intuitive and user-centered experiences.',
} = Astro.props;

const fullTitle = title === 'Kristian Kim' ? title : `Kristian Kim — ${title}`;
const pathname = Astro.url.pathname;
const easternTimeFormatter = new Intl.DateTimeFormat('en-US', {
  timeZone: 'America/New_York',
  hour: 'numeric',
  minute: '2-digit',
  hour12: true,
  timeZoneName: 'short',
});
const initialEasternTime = easternTimeFormatter.format(new Date()).replace(/\s(?=[A-Z]{3}$)/, '');

const isHome = pathname === '/';

const navItems = [
  { href: '/works', label: 'Works' },
  { href: '/thoughts', label: 'Writings' },
  { href: '/about', label: 'About' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;700&family=Geist+Mono:wght@700&family=EB+Garamond:ital,wght@0,400;0,500;1,400;1,500&display=swap"
      rel="stylesheet"
    />
    <title>{fullTitle}</title>
    <link rel="icon" type="image/png" href="/favicon-light.png" media="(prefers-color-scheme: light)" />
    <link rel="icon" type="image/png" href="/favicon-dark.png" media="(prefers-color-scheme: dark)" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  </head>
  <body>
    <header id="topnav" class="topnav">
      <div class="site-shell topnav-inner">
        <a class="brand" href="/"><img src="/images/kk-logo.svg" alt="Kristian Kim" width="32" height="32" /></a>
        <nav class="site-nav" aria-label="Primary">
          {navItems.map((item) => (
            <a href={item.href} class={item.href.startsWith('/') && item.href !== '/' && pathname.startsWith(item.href) ? 'active' : ''}>{item.label}</a>
          ))}
        </nav>
        <div class="nav-spacer" aria-hidden="true"></div>
      </div>
    </header>

    <main class="site-shell">
      <slot />
    </main>

    <footer class="site-footer site-shell" aria-label="Site footer">
      <div class="site-footer-inner">
        <p class="footer-copy">© 2026 Kristian Kim</p>
        <div class="footer-meta" aria-label="Location and note">
          <p id="footer-time" aria-label="Current Eastern Time">{initialEasternTime}</p>
          <p>John 3:16</p>
        </div>
      </div>
    </footer>

    <script>
      import Lenis from 'lenis';

      // ─── Smooth scroll ────────────────────────────────────────────────────
      const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
      let lenis: Lenis | undefined;

      // Keep touch scrolling native and respect the visitor's OS motion setting.
      if (!reducedMotion.matches) {
        lenis = new Lenis({
          autoRaf: true,
          lerp: 0.075,
          smoothWheel: true,
          syncTouch: false,
          wheelMultiplier: 1,
          anchors: true,
        });
      }

      // ─── Nav scroll state ────────────────────────────────────────────────
      const nav = document.getElementById('topnav');
      window.addEventListener('scroll', () => {
        if (!nav) return;
        nav.classList.toggle('scrolled', window.scrollY > 12);
      }, { passive: true });

      // ─── Footer time ─────────────────────────────────────────────────────
      const footerTime = document.getElementById('footer-time');
      let footerTimer: number | undefined;
      if (footerTime) {
        const formatter = new Intl.DateTimeFormat('en-US', {
          timeZone: 'America/New_York',
          hour: 'numeric',
          minute: '2-digit',
          hour12: true,
          timeZoneName: 'short',
        });
        const updateFooterTime = () => {
          footerTime.textContent = formatter.format(new Date()).replace(/\s(?=[A-Z]{3}$)/, '');
        };
        updateFooterTime();
        footerTimer = window.setInterval(updateFooterTime, 30_000);
      }

      // ─── Reveal animations ───────────────────────────────────────────────
      const REVEAL_SELECTOR = [
        '.hero-intro',
        '.hero-body',
        '.hero-visual',
        '.section-header',
        '.project-row',
        '.writing-row',
        '.selected-work-card',
        '.playground-card',
        '.about-title',
        '.about-photo',
        '.principle',
        '.list > .item',
        '.work-hero > *',
        '.thought-hero > *',
        '.content-section',
        '.metric-card',
        '.gallery-grid > *',
        '.callout-block',
        '.quote-block',
        '.reveal-item',
      ].join(', ');

      const allNodes = Array.from(document.querySelectorAll<HTMLElement>(REVEAL_SELECTOR));

      allNodes.forEach((node) => {
        node.classList.add('reveal-item');
      });

      let observer: IntersectionObserver | undefined;
      if (reducedMotion.matches || !('IntersectionObserver' in window)) {
        allNodes.forEach((node) => node.classList.add('is-visible'));
      } else {
        document.documentElement.classList.add('motion-ready');

        observer = new IntersectionObserver((entries) => {
          const visible = entries
            .filter((entry) => entry.isIntersecting)
            .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);

          visible.forEach((entry, index) => {
            const target = entry.target as HTMLElement;
            target.style.setProperty('--reveal-delay', `${Math.min(index * 70, 210)}ms`);
            target.classList.add('is-visible');
            observer?.unobserve(target);
          });
        }, {
          threshold: 0.08,
          rootMargin: '0px 0px -8% 0px',
        });

        allNodes.forEach((node) => observer?.observe(node));
      }

      window.addEventListener('pagehide', (event) => {
        if (event.persisted) return;
        if (footerTimer) window.clearInterval(footerTimer);
        observer?.disconnect();
        lenis?.destroy();
      }, { once: true });
    </script>
  </body>
</html>

<style is:global>
  @font-face {
    font-family: 'Gambarino';
    src: url('/fonts/Gambarino-Regular.woff2') format('woff2');
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }

  :root {
    --color-white-wild-sand: #faf9f6;
    --page-bg: var(--color-white-wild-sand);
    --surface: rgba(255, 255, 255, 0.7);
    --surface-strong: rgba(255, 255, 255, 0.86);
    --text: #171717;
    --muted: #626262;
    --line: #e8e8e8;
    --line-strong: #bababa;
    --container: min(960px, calc(100vw - 32px));
    --gutter: clamp(16px, 1.25vw, 24px);
    --font-sans: 'Geist', 'Helvetica Neue', Helvetica, Arial, sans-serif;
    --font-mono: 'Geist Mono', 'SFMono-Regular', Consolas, monospace;
    --font-serif: 'EB Garamond', Georgia, serif;
  }

  * {
    box-sizing: border-box;
  }

  html:not(.lenis) {
    scroll-behavior: smooth;
  }

  html {
    color-scheme: light;
  }

  html.lenis,
  html.lenis body {
    height: auto;
  }

  .lenis:not(.lenis-autoToggle).lenis-stopped {
    overflow: clip;
  }

  .lenis [data-lenis-prevent],
  .lenis [data-lenis-prevent-wheel],
  .lenis [data-lenis-prevent-touch],
  .lenis [data-lenis-prevent-vertical],
  .lenis [data-lenis-prevent-horizontal] {
    overscroll-behavior: contain;
  }

  .lenis.lenis-smooth iframe {
    pointer-events: none;
  }

  body {
    margin: 0;
    min-width: 320px;
    background: var(--page-bg);
    color: var(--text);
    font-family: var(--font-sans);
    font-size: 16px;
    line-height: 1.375;
    text-rendering: optimizeLegibility;
    -webkit-font-smoothing: antialiased;
  }

  img {
    display: block;
    max-width: 100%;
  }

  a {
    color: inherit;
  }

  p {
    margin: 0;
    color: var(--muted);
    font-size: 16px;
    line-height: 1.375;
  }

  h1,
  h2 {
    margin: 0;
    color: var(--text);
    font-family: var(--font-serif);
    font-weight: 400;
    letter-spacing: 0;
  }

  h3,
  h4,
  h5,
  h6 {
    margin: 0;
    color: var(--text);
    font-weight: 400;
  }

  .site-shell {
    width: var(--container);
    margin: 0 auto;
  }

  .twelve-col {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    gap: var(--gutter);
  }

  .section-block {
    margin-top: 56px;
  }

  .section-header {
    padding-bottom: 8px;
    border-bottom: 1px solid var(--text);
    margin-bottom: 24px;
  }

  .section-heading {
    font-family: var(--font-sans);
    font-size: 16px;
    line-height: 1.5;
    font-weight: 700;
    color: var(--text);
  }

  .detail-copy p + p {
    margin-top: 0;
  }

  .detail-copy a {
    color: inherit;
    text-underline-offset: 3px;
  }

  .detail-copy a:hover {
    color: var(--text);
  }

  .topnav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(250, 249, 246, 0.82);
    border-bottom: 1px solid rgba(232, 232, 232, 0.9);
    backdrop-filter: blur(14px) saturate(135%);
    -webkit-backdrop-filter: blur(14px) saturate(135%);
    transition: background 180ms ease, box-shadow 180ms ease;
  }

  .topnav.scrolled {
    background: rgba(250, 249, 246, 0.92);
    box-shadow: 0 10px 30px rgba(23, 23, 23, 0.05);
  }

  .topnav-inner {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    gap: var(--gutter);
    align-items: center;
    min-height: 45px;
    padding: 0;
  }

  .brand {
    grid-column: span 4;
    text-decoration: none;
    display: flex;
    align-items: center;
    white-space: nowrap;
  }

  .brand img {
    display: block;
    width: 32px;
    height: 32px;
  }

  .site-nav {
    grid-column: 9 / span 4;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 16px;
  }

  .site-nav a {
    color: var(--muted);
    text-decoration: none;
    font-size: 14px;
    line-height: 1.2857;
    transition: color 160ms ease;
  }

  .site-nav a:hover,
  .site-nav a.active {
    color: var(--text);
  }

  .nav-spacer {
    display: none;
  }

  main {
    padding: 40px 0 80px;
  }

  .site-footer {
    padding: 0 0 28px;
  }

  .site-footer-inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    gap: 16px;
    padding-top: 12px;
    border-top: 1px solid var(--line);
  }

  .site-footer p {
    margin: 0;
    color: var(--muted);
    font-size: 12px;
    line-height: 1.2;
  }

  .footer-meta {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 24px;
    text-align: right;
  }

  /* Page entrance — subtle fade in on first load */
  @keyframes page-enter {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  body {
    animation: page-enter 480ms ease forwards;
  }

  /* Hide reveal elements only after JavaScript has initialized. */
  .motion-ready .reveal-item {
    opacity: 0;
    transform: translate3d(0, 24px, 0);
    transition:
      opacity 720ms cubic-bezier(0.16, 1, 0.3, 1) var(--reveal-delay, 0ms),
      transform 820ms cubic-bezier(0.16, 1, 0.3, 1) var(--reveal-delay, 0ms);
  }

  .motion-ready .reveal-item.is-visible {
    opacity: 1;
    transform: translate3d(0, 0, 0);
  }

  @media (prefers-reduced-motion: reduce) {
    body { animation: none; }

    html { scroll-behavior: auto; }

    .reveal-item {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }

  @media (max-width: 980px) {
    .topnav-inner {
      grid-template-columns: 1fr;
      gap: 6px;
      padding: 10px 0;
    }

    .brand,
    .site-nav,
    .nav-spacer {
      grid-column: auto;
    }

    .site-nav {
      justify-content: flex-start;
      overflow-x: auto;
      padding-bottom: 2px;
    }

    .twelve-col {
      grid-template-columns: 1fr;
      gap: 20px;
    }

    .section-block {
      margin-top: 44px;
    }

    main {
      padding: 28px 0 64px;
    }

    .site-footer {
      padding-bottom: 20px;
    }

    .site-footer-inner {
      grid-template-columns: 1fr;
      align-items: flex-start;
      gap: 10px;
    }

    .footer-meta {
      width: 100%;
      justify-content: space-between;
      gap: 12px;
      text-align: left;
    }
  }
</style>
