---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Kristian Kim',
  description = 'Product designer crafting intuitive and user-centered experiences.',
} = Astro.props;

const fullTitle = title === 'Kristian Kim' ? title : `Kristian Kim — ${title}`;
const pathname = Astro.url.pathname;

const navItems = [
  { href: '/works', label: 'Works' },
  { href: '/thoughts', label: 'Thoughts' },
  { href: '/about', label: 'About' },
  { href: '/tokens', label: 'Tokens' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;700&family=Geist+Mono:wght@700&display=swap"
      rel="stylesheet"
    />
    <title>{fullTitle}</title>
  </head>
  <body>
    <header id="topnav" class="topnav">
      <div class="site-shell topnav-inner">
        <a class="brand" href="/">Kristian Kim</a>
        <nav class="site-nav" aria-label="Primary">
          {navItems.map((item) => (
            <a href={item.href} class={pathname.startsWith(item.href) ? 'active' : ''}>{item.label}</a>
          ))}
        </nav>
        <div class="nav-spacer" aria-hidden="true"></div>
      </div>
    </header>

    <main class="site-shell">
      <slot />
    </main>

    <script type="module">
      import Lenis from 'lenis';

      const nav = document.getElementById('topnav');

      const lenis = new Lenis({
        duration: 1.05,
        smoothWheel: true,
        wheelMultiplier: 0.9,
        touchMultiplier: 1.1,
      });

      function raf(time) {
        lenis.raf(time);
        requestAnimationFrame(raf);
      }

      requestAnimationFrame(raf);

      window.addEventListener('scroll', () => {
        if (!nav) return;
        nav.classList.toggle('scrolled', window.scrollY > 12);
      }, { passive: true });

      const revealNodes = document.querySelectorAll(
        '.reveal-item, .hero-intro, .hero-body, .hero-visual, .section-heading, .project-row, .writing-row, .playground-card, .detail-copy'
      );

      revealNodes.forEach((node, idx) => {
        if (!node.classList.contains('reveal-item')) node.classList.add('reveal-item');
        node.style.setProperty('--reveal-delay', `${Math.min(idx * 55, 280)}ms`);
      });

      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.12, rootMargin: '0px 0px -10% 0px' });

      revealNodes.forEach((node) => observer.observe(node));
    </script>
  </body>
</html>

<style is:global>
  @font-face {
    font-family: 'Gambarino';
    src: url('/fonts/Gambarino-Regular.woff2') format('woff2');
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }

  :root {
    --page-bg: #faf9f6;
    --surface: rgba(255, 255, 255, 0.7);
    --surface-strong: rgba(255, 255, 255, 0.86);
    --text: #171717;
    --muted: #626262;
    --line: #e8e8e8;
    --line-strong: #bababa;
    --container: min(1680px, calc(100vw - 32px));
    --gutter: clamp(16px, 1.25vw, 24px);
    --font-sans: 'Geist', 'Helvetica Neue', Helvetica, Arial, sans-serif;
    --font-mono: 'Geist Mono', 'SFMono-Regular', Consolas, monospace;
    --font-serif: 'Gambarino', Georgia, serif;
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
    color-scheme: light;
  }

  body {
    margin: 0;
    min-width: 320px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.54), rgba(255, 255, 255, 0.18)),
      var(--page-bg);
    color: var(--text);
    font-family: var(--font-sans);
    font-size: 16px;
    line-height: 1.375;
    text-rendering: optimizeLegibility;
    -webkit-font-smoothing: antialiased;
  }

  img {
    display: block;
    max-width: 100%;
  }

  a {
    color: inherit;
  }

  p {
    margin: 0;
    color: var(--muted);
    font-size: 16px;
    line-height: 1.375;
  }

  h1,
  h2 {
    margin: 0;
    color: var(--text);
    font-family: var(--font-serif);
    font-weight: 400;
    letter-spacing: 0;
  }

  h3,
  h4,
  h5,
  h6 {
    margin: 0;
    color: var(--text);
    font-weight: 400;
  }

  .site-shell {
    width: var(--container);
    margin: 0 auto;
  }

  .twelve-col {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    gap: var(--gutter);
  }

  .section-block {
    margin-top: 56px;
  }

  .section-header {
    padding-bottom: 8px;
    border-bottom: 1px solid var(--text);
    margin-bottom: 24px;
  }

  .section-heading {
    font-family: var(--font-mono);
    font-size: 16px;
    line-height: 1.5;
    font-weight: 700;
    color: var(--muted);
  }

  .detail-copy p + p {
    margin-top: 16px;
  }

  .topnav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(250, 249, 246, 0.82);
    border-bottom: 1px solid rgba(232, 232, 232, 0.9);
    backdrop-filter: blur(14px) saturate(135%);
    -webkit-backdrop-filter: blur(14px) saturate(135%);
    transition: background 180ms ease, box-shadow 180ms ease;
  }

  .topnav.scrolled {
    background: rgba(250, 249, 246, 0.92);
    box-shadow: 0 10px 30px rgba(23, 23, 23, 0.05);
  }

  .topnav-inner {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    gap: var(--gutter);
    align-items: center;
    min-height: 45px;
    padding: 0;
  }

  .brand {
    grid-column: span 4;
    text-decoration: none;
    font-size: 16px;
    line-height: 1.3125;
    font-weight: 700;
    white-space: nowrap;
  }

  .site-nav {
    grid-column: span 4;
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .site-nav a {
    color: var(--muted);
    text-decoration: none;
    font-size: 14px;
    line-height: 1.2857;
    transition: color 160ms ease;
  }

  .site-nav a:hover,
  .site-nav a.active {
    color: var(--text);
  }

  .nav-spacer {
    grid-column: span 4;
  }

  main {
    padding: 40px 0 80px;
  }

  .reveal-item {
    opacity: 0;
    transform: translateY(18px);
    transition:
      opacity 720ms cubic-bezier(.22, .61, .36, 1) var(--reveal-delay, 0ms),
      transform 720ms cubic-bezier(.22, .61, .36, 1) var(--reveal-delay, 0ms);
  }

  .reveal-item.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    html {
      scroll-behavior: auto;
    }

    .reveal-item {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }

  @media (max-width: 980px) {
    .topnav-inner {
      grid-template-columns: 1fr;
      gap: 6px;
      padding: 10px 0;
    }

    .brand,
    .site-nav,
    .nav-spacer {
      grid-column: auto;
    }

    .site-nav {
      overflow-x: auto;
      padding-bottom: 2px;
    }

    .twelve-col {
      grid-template-columns: 1fr;
      gap: 20px;
    }

    .section-block {
      margin-top: 44px;
    }

    main {
      padding: 28px 0 64px;
    }
  }
</style>
